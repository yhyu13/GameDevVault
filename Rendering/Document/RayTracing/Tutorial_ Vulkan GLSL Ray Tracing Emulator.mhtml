arkgreen;">// unused
</span>}; <span style=3D"color:darkgreen;">// type of the "hit" variable
</span>
<span style=3D"color:darkgreen;">// Returns a camera ray for a camera at th=
e origin that is looking in negative z-direction.
</span><span style=3D"color:darkgreen;">// "fieldOfViewY" must be given in =
degrees.
</span><span style=3D"color:darkgreen;">// "point" must be in range [0.0, 1=
.0] to cover the complete image plane.
</span><span style=3D"color:darkgreen;">//
</span><span style=3D"color:#930f80;">vec3</span> getCameraRay(<span style=
=3D"color:#930f80;">float</span> fieldOfViewY, <span style=3D"color:#930f80=
