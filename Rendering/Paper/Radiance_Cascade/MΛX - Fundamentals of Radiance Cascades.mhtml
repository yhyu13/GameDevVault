ec2</span><span>(</span><span style=3D"color:#eaae2e">0</span><span>, </spa=
n><span style=3D"color:#eaae2e">1</span><span>), </span><span style=3D"colo=
r:#95cc5e">ivec2</span><span>(</span><span style=3D"color:#eaae2e">1</span>=
<span>, </span><span style=3D"color:#eaae2e">1</span><span>) };
