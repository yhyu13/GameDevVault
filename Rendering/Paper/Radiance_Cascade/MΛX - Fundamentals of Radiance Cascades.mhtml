r:#eaae2e">4</span><span>] </span><span style=3D"color:#db784d">=3D </span>=
<span>{ </span><span style=3D"color:#95cc5e">ivec2</span><span>(</span><spa=
n style=3D"color:#eaae2e">0</span><span>, </span><span style=3D"color:#eaae=
2e">0</span><span>), </span><span style=3D"color:#95cc5e">ivec2</span><span=
>(</span><span style=3D"color:#eaae2e">1</span><span>, </span><span style=
