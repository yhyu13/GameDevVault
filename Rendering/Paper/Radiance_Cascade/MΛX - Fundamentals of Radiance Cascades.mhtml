ffsets[offset_index];
</span><span>}
</span></code></pre><p>We can add our <code>base_offset</code> to the <code=
>base_index</code> we got <span class=3D"highlight">earlier</span> to get t=
he <strong>2D</strong> index of the bilinear probe.</p><pre class=3D"langua=
ge-glsl" data-lang=3D"glsl" style=3D"color:#e8d4c0;background-color:#191919=
"><code class=3D"language-glsl" data-lang=3D"glsl"><span style=3D"color:#7a=
7267">/* Get the index of the bilinear probe to merge with */
</span><span style=3D"color:#db784d">const </span><span style=3D"color:#95c=
c5e">ivec2</span><span> bilinear_index </span><span style=3D"color:#db784d"=
>=3D</span><span> base_index </span><span style=3D"color:#db784d">+</span><=
span> base_offset;
</span></code></pre><p>Now it is relatively trivial to use our <code>dir_in=
dex</code> we learned how to get earlier.<br data-filtered=3D"filtered"> To=
 get a directional <code>base_index</code> and add <code>d</code> to it.</p=
><pre class=3D"language-glsl" data-lang=3D"glsl" style=3D"color:#e8d4c0;bac=
kground-color:#191919"><code class=3D"language-glsl" data-lang=3D"glsl"><sp=
an style=3D"color:#7a7267">/* Get the directional base index */
</span><span style=3D"color:#db784d">const </span><span style=3D"color:#95c=
c5e">int</span><span> base_dir_index </span><span style=3D"color:#db784d">=
=3D</span><span> dir_index </span><span style=3D"color:#db784d">* </span><s=
pan style=3D"color:#eaae2e">4</span><span>;
</span><span>
</span><span style=3D"color:#7a7267">/* Get the directional index we want t=
o merge with */
</span><span style=3D"color:#db784d">const </span><span style=3D"color:#95c=
c5e">int</span><span> bilinear_dir_index </span><span style=3D"color:#db784=
d">=3D</span><span> base_dir_index </span><span style=3D"color:#db784d">+</=
span><span> d;
</span></code></pre><p>Then finally we can combine the <code>bilinear_dir_i=
ndex</code> &amp; <code>bilinear_index</code> to get the <span class=3D"hig=
hlight">texel</span> coordinate in cascade <strong>N+1</strong> to merge wi=
th.</p><pre class=3D"language-glsl" data-lang=3D"glsl" style=3D"color:#e8d4=
c0;background-color:#191919"><code class=3D"language-glsl" data-lang=3D"gls=
l"><span style=3D"color:#7a7267">/* Convert the directional index to a loca=
l texel coordinate */
</span><span style=3D"color:#db784d">const </span><span style=3D"color:#95c=
c5e">ivec2</span><span> bilinear_dir_coord </span><span style=3D"color:#db7=
84d">=3D </span><span style=3D"color:#95cc5e">ivec2</span><span>(
</span><span>    bilinear_dir_index </span><span style=3D"color:#db784d">%<=
/span><span> bilinear_size.</span><span style=3D"color:#f8bb39">x</span><sp=
an>,
</span><span>    bilinear_dir_index </span><span style=3D"color:#db784d">/<=
/span><span> bilinear_size.</span><span style=3D"color:#f8bb39">x
