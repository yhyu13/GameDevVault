@charset "utf-8";

#colorbox, #cboxOverlay, #cboxWrapper { position: absolute; top: 0px; left:=
 0px; z-index: 9999; overflow: hidden; transform: translate3d(0px, 0px, 0px=
); }

#cboxWrapper { max-width: none; }

#cboxOverlay { position: fixed; width: 100%; height: 100%; }

#cboxMiddleLeft, #cboxBottomLeft { clear: left; }

#cboxContent { position: relative; }

#cboxLoadedContent { overflow: auto; }

#cboxTitle { margin: 0px; }

#cboxLoadingOverlay, #cboxLoadingGraphic { position: absolute; top: 0px; le=
ft: 0px; width: 100%; height: 100%; }

#cboxPrevious, #cboxNext, #cboxClose, #cboxSlideshow { cursor: pointer; }

.cboxPhoto { float: left; margin: auto; border: 0px; display: block; max-wi=
dth: none; }

.cboxIframe { width: 100%; height: 100%; display: block; border: 0px; paddi=
ng: 0px; margin: 0px; }

#colorbox, #cboxContent, #cboxLoadedContent { box-sizing: content-box; }

#cboxOverlay { background: rgb(0, 0, 0); opacity: 0.9; }

#colorbox { outline: 0px; }

#cboxTopLeft { width: 14px; height: 43px; background: url("images/controls-=
2.png") 0px 0px no-repeat; }

#cboxTopCenter { height: 43px; background: url("images/border-2.png") left =
top repeat-x; }

#cboxTopRight { width: 14px; height: 43px; background: url("images/controls=
-2.png") -36px 0px no-repeat; }

#cboxBottomLeft { width: 14px; height: 14px; background: url("images/contro=
ls-2.png") 0px -61px no-repeat; }

#cboxBottomCenter { height: 14px; background: url("images/border-2.png") le=
ft bottom repeat-x; }

#cboxBottomRight { width: 14px; height: 14px; background: url("images/contr=
ols-2.png") -36px -61px no-repeat; }

#cboxMiddleLeft { width: 14px; background: url("images/controls-2.png") -17=
5px 0px repeat-y; }

#cboxMiddleRight { width: 14px; background: url("images/controls-2.png") -2=
11px 0px repeat-y; }

#cboxContent { background: rgb(255, 255, 255); overflow: visible; }

.cboxIframe { background: rgb(255, 255, 255); }

#cboxError { padding: 50px; border: 1px solid rgb(204, 204, 204); }

#cboxLoadedContent { margin-top: 5px; }

#cboxLoadingOverlay { background: url("images/loading_background.png") cent=
er center no-repeat; }

#cboxLoadingGraphic { background: url("images/loading.gif") center center n=
o-repeat; }

#cboxTitle { position: absolute; top: -25px; left: 0px; text-align: center;=
 width: 100%; font-weight: bold; color: rgb(124, 124, 124); }

#cboxCurrent { position: absolute; top: -25px; left: 58px; font-weight: bol=
d; color: rgb(124, 124, 124); }

#cboxPrevious, #cboxNext, #cboxSlideshow, #cboxClose { border: 0px; padding=
: 0px; margin: 0px; overflow: visible; position: absolute; bottom: -29px; b=
ackground: url("images/controls-2.png") 0px 0px no-repeat; width: 23px; hei=
ght: 23px; text-indent: -9999px; }

#cboxPrevious:active, #cboxNext:active, #cboxSlideshow:active, #cboxClose:a=
ctive { outline: 0px; }

#cboxPrevious { top: -30px; left: 0px; background-position: -51px -25px; }

#cboxPrevious:hover { background-position: -51px 0px; }

#cboxNext { top: -30px; left: 27px; background-position: -75px -25px; }

#cboxNext:hover { background-position: -75px 0px; }

#cboxClose { top: -30px; right: 0px; background-position: -100px -25px; }

#cboxClose:hover { background-position: -100px 0px; }

.cboxSlideshow_on #cboxSlideshow { background-position: -125px 0px; top: -3=
0px; right: 27px; }

.cboxSlideshow_on #cboxSlideshow:hover { background-position: -150px 0px; }

.cboxSlideshow_off #cboxSlideshow { background-position: -150px -25px; top:=
 -30px; right: 27px; }

.cboxSlideshow_off #cboxSlideshow:hover { background-position: -125px 0px; }
