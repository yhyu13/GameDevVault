+// Copyright Epic Games, Inc. All Rights Reserved.
+
+#include "CustomMcpEditorToolLibrary.h"
+
+#include "Editor.h"
+#include "Engine/World.h"
+#include "EngineUtils.h"
+#include "Selection.h"
+
+UCustomMcpEditorToolLibrary::UCustomMcpEditorToolLibrary()
+{
+	bAutoRegisterTools = true;
+}
+
+FActorListResult UCustomMcpEditorToolLibrary::ListActors()
+{
+	FActorListResult Result;
+	if (UWorld* World = GEditor->GetEditorWorldContext().World())
+	{
+		for (TActorIterator<AActor> It(World); It; ++It)
+		{
+			FActorListEntry Entry;
+			Entry.Name = It->GetName();
+			Entry.Class = It->GetClass()->GetName();
+			Entry.Location = It->GetActorLocation();
+			Result.Actors.Add(Entry);
+		}
+	}
+	return Result;
+}
+
+FActorDetailsResult UCustomMcpEditorToolLibrary::GetActorDetails(const FString& ActorName)
+{
+	FActorDetailsResult Result;
+	if (UWorld* World = GEditor->GetEditorWorldContext().World())
+	{
+		for (TActorIterator<AActor> It(World); It; ++It)
+		{
+			if (It->GetName() == ActorName)
+			{
+				Result.Name = It->GetName();
+				Result.Class = It->GetClass()->GetName();
+				Result.Location = It->GetActorLocation();
+				Result.Rotation = It->GetActorRotation();
+				Result.Scale = It->GetActorScale3D();
+				Result.bIsSelected = GEditor->GetSelectedActors()->IsSelected(*It);
+				break;
+			}
+		}
+	}
+	return Result;
+}
+
+FSpawnActorResult UCustomMcpEditorToolLibrary::SpawnActor(
+	const FString& ClassName,
+	const FVector& Location,
+	const FRotator& Rotation,
+	const FVector& Scale)
+{
+	FSpawnActorResult Result;
+	UClass* ActorClass = FindObject<UClass>(nullptr, *ClassName, EFindObjectFlags::ExactClass);
+	if (!ActorClass)
+	{
+		Result.ErrorMessage = FString::Printf(TEXT("Actor class not found: %s"), *ClassName);
+		return Result;
+	}
+
+	if (UWorld* World = GEditor->GetEditorWorldContext().World())
+	{
+		FActorSpawnParameters SpawnParams;
+		SpawnParams.bNoFail = false;
+		AActor* Actor = World->SpawnActor<AActor>(ActorClass, Location, Rotation, SpawnParams);
+		if (Actor)
+		{
+			Actor->SetActorScale3D(Scale);
+			Result.ActorName = Actor->GetName();
+			Result.bSuccess = true;
+		}
+		else
+		{
+			Result.ErrorMessage = TEXT("Failed to spawn actor at the specified location");
+		}
+	}
+	else
+	{
+		Result.ErrorMessage = TEXT("No editor world available");
+	}
+	return Result;
+}
+
+FDeleteActorResult UCustomMcpEditorToolLibrary::DeleteActor(const FString& ActorName)
+{
+	FDeleteActorResult Result;
+	if (UWorld* World = GEditor->GetEditorWorldContext().World())
+	{
+		TArray<AActor*> MatchingActors;
+		for (TActorIterator<AActor> It(World); It; ++It)
+		{
+			if (It->GetName() == ActorName)
+			{
+				MatchingActors.Add(*It);
+			}
+		}
+
+		if (MatchingActors.Num() == 0)
+		{
+			Result.ErrorMessage = FString::Printf(TEXT("Actor not found: %s"), *ActorName);
+		}
+		else if (MatchingActors.Num() > 1)
+		{
+			Result.ErrorMessage = FString::Printf(TEXT("Multiple actors found with name '%s' (%d total). Please use a unique name."), *ActorName, MatchingActors.Num());
+		}
+		else
+		{
+			MatchingActors[0]->Destroy();
+			Result.bSuccess = true;
+		}
+	}
+	else
+	{
+		Result.ErrorMessage = TEXT("No editor world available");
+	}
+	return Result;
+}
+
+FSetTransformResult UCustomMcpEditorToolLibrary::SetActorTransform(
+	const FString& ActorName,
+	const FVector& Location,
+	const FRotator& Rotation,
+	const FVector& Scale)
+{
+	FSetTransformResult Result;
+	if (UWorld* World = GEditor->GetEditorWorldContext().World())
+	{
+		for (TActorIterator<AActor> It(World); It; ++It)
+		{
+			if (It->GetName() == ActorName)
+			{
+				It->SetActorLocation(Location);
+				It->SetActorRotation(Rotation);
+				It->SetActorScale3D(Scale);
+				Result.bSuccess = true;
+				break;
+			}
+		}
+	}
+	if (!Result.bSuccess)
+	{
+		Result.ErrorMessage = FString::Printf(TEXT("Actor not found: %s"), *ActorName);
+	}
+	return Result;
+}
