+/**
+ * Custom MCP editor tool library providing lightweight actor inspection and mutation tools.
+ * UFUNCTIONs are automatically registered as MCP tools on module load.
+ */
+UCLASS()
+class UCustomMcpEditorToolLibrary : public UModelContextProtocolEditorToolLibrary
+{
+	GENERATED_BODY()
+
+public:
+	UCustomMcpEditorToolLibrary();
+
+	/** List all actors in the current editor level */
+	UFUNCTION(BlueprintCallable, Category = "MCP Editor Tools", meta = (ToolTip = "List all actors in the current editor level with their names, classes, and locations"))
+	static FActorListResult ListActors();
+
+	/** Get detailed information about a specific actor by name */
+	UFUNCTION(BlueprintCallable, Category = "MCP Editor Tools", meta = (ToolTip = "Get detailed information about a specific actor by name, including transform and selection state"))
+	static FActorDetailsResult GetActorDetails(const FString& ActorName);
+
+	/** Spawn an actor of the specified class at the given location */
+	UFUNCTION(BlueprintCallable, Category = "MCP Editor Tools", meta = (ToolTip = "Spawn an actor of the specified class at the given location, rotation, and scale"))
+	static FSpawnActorResult SpawnActor(
+		const FString& ClassName,
+		const FVector& Location,
+		const FRotator& Rotation,
+		const FVector& Scale);
+
+	/** Delete an actor by name from the current level */
+	UFUNCTION(BlueprintCallable, Category = "MCP Editor Tools", meta = (ToolTip = "Delete an actor by name from the current level. Returns error if multiple actors share the name"))
+	static FDeleteActorResult DeleteActor(const FString& ActorName);
+
+	/** Set the transform (location, rotation, scale) of an actor by name */
+	UFUNCTION(BlueprintCallable, Category = "MCP Editor Tools", meta = (ToolTip = "Set the transform (location, rotation, scale) of an actor by name"))
+	static FSetTransformResult SetActorTransform(
+		const FString& ActorName,
+		const FVector& Location,
+		const FRotator& Rotation,
+		const FVector& Scale);
+};
