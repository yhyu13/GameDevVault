+// Copyright Epic Games, Inc. All Rights Reserved.
+
+#include "ModelContextProtocolSaveLevelTool.h"
+#include "ModelContextProtocolToolResults.h"
+
+#if WITH_EDITOR
+#include "Editor.h"
+#include "FileHelpers.h"
+#include "Engine/Level.h"
+#include "Engine/World.h"
+#endif
+
+FString FModelContextProtocolSaveLevelTool::GetName() const
+{
+	return TEXT("save_current_level");
+}
+
+FString FModelContextProtocolSaveLevelTool::GetDescription() const
+{
+	return TEXT("Save the current level to disk");
+}
+
+TSharedPtr<FJsonObject> FModelContextProtocolSaveLevelTool::GetInputJsonSchema() const
+{
+	return nullptr;
+}
+
+TSharedPtr<FJsonObject> FModelContextProtocolSaveLevelTool::GetOutputJsonSchema() const
+{
+	return nullptr;
+}
+
+FModelContextProtocolToolResult FModelContextProtocolSaveLevelTool::Run(const TSharedPtr<FJsonObject>& Params)
+{
+#if WITH_EDITOR
+	UWorld* World = GEditor->GetEditorWorldContext().World();
+	if (!World)
+	{
+		return UE::ModelContextProtocol::MakeErrorResult(TEXT("No editor world available"));
+	}
+
+	ULevel* Level = World->GetCurrentLevel();
+	if (!Level)
+	{
+		return UE::ModelContextProtocol::MakeErrorResult(TEXT("No current level"));
+	}
+
+	FEditorFileUtils::SaveLevel(Level);
+	return UE::ModelContextProtocol::MakeTextResult(TEXT("Level saved successfully"));
+#else
+	return UE::ModelContextProtocol::MakeErrorResult(TEXT("Save level is only available in editor"));
+#endif
+}
