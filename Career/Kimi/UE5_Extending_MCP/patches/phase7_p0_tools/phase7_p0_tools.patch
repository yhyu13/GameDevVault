+void FModelContextProtocolEditorModule::RegisterBuiltinEditorTools()
+{
+	IModelContextProtocolModule* Module = IModelContextProtocolModule::Get();
+	if (!Module)
+	{
+		return;
+	}
+
+	EditorContextTool = MakeShared<FModelContextProtocolEditorContextTool>();
+	if (Module->AddTool(EditorContextTool.ToSharedRef()))
+	{
+		UE_LOGF(LogModelContextProtocol, Log, "Registered built-in editor tool: get_editor_context");
+	}
+
+	ViewportTool = MakeShared<FModelContextProtocolViewportTool>();
+	if (Module->AddTool(ViewportTool.ToSharedRef()))
+	{
+		UE_LOGF(LogModelContextProtocol, Log, "Registered built-in editor tool: capture_viewport");
+	}
+
+	SaveLevelTool = MakeShared<FModelContextProtocolSaveLevelTool>();
+	if (Module->AddTool(SaveLevelTool.ToSharedRef()))
+	{
+		UE_LOGF(LogModelContextProtocol, Log, "Registered built-in editor tool: save_current_level");
+	}
+
+	ListLevelsTool = MakeShared<FModelContextProtocolListLevelsTool>();
+	if (Module->AddTool(ListLevelsTool.ToSharedRef()))
+	{
+		UE_LOGF(LogModelContextProtocol, Log, "Registered built-in editor tool: list_levels");
+	}
+
+	ClassInventoryTool = MakeShared<FModelContextProtocolClassInventoryTool>();
+	if (Module->AddTool(ClassInventoryTool.ToSharedRef()))
+	{
+		UE_LOGF(LogModelContextProtocol, Log, "Registered built-in editor tool: class_inventory");
+	}
+
+	OpenLevelTool = MakeShared<FModelContextProtocolOpenLevelTool>();
+	if (Module->AddTool(OpenLevelTool.ToSharedRef()))
+	{
+		UE_LOGF(LogModelContextProtocol, Log, "Registered built-in editor tool: open_level");
+	}
+
+	SnapshotWorldTool = MakeShared<FModelContextProtocolSnapshotWorldTool>();
+	if (Module->AddTool(SnapshotWorldTool.ToSharedRef()))
+	{
+		UE_LOGF(LogModelContextProtocol, Log, "Registered built-in editor tool: snapshot_world");
+	}
+
+	RestoreWorldTool = MakeShared<FModelContextProtocolRestoreWorldTool>();
+	if (Module->AddTool(RestoreWorldTool.ToSharedRef()))
+	{
+		UE_LOGF(LogModelContextProtocol, Log, "Registered built-in editor tool: restore_world");
+	}
+
+	SpawnActorTool = MakeShared<FModelContextProtocolSpawnActorTool>();
+	if (Module->AddTool(SpawnActorTool.ToSharedRef()))
+	{
+		UE_LOGF(LogModelContextProtocol, Log, "Registered built-in editor tool: spawn_actor");
+	}
+
+	SetActorTransformTool = MakeShared<FModelContextProtocolSetActorTransformTool>();
+	if (Module->AddTool(SetActorTransformTool.ToSharedRef()))
+	{
+		UE_LOGF(LogModelContextProtocol, Log, "Registered built-in editor tool: set_actor_transform");
+	}
+
+	VerifyPositionTool = MakeShared<FModelContextProtocolVerifyPositionTool>();
+	if (Module->AddTool(VerifyPositionTool.ToSharedRef()))
+	{
+		UE_LOGF(LogModelContextProtocol, Log, "Registered built-in editor tool: verify_position");
+	}
+
+	SummarizeSceneTool = MakeShared<FModelContextProtocolSummarizeSceneTool>();
+	if (Module->AddTool(SummarizeSceneTool.ToSharedRef()))
+	{
+		UE_LOGF(LogModelContextProtocol, Log, "Registered built-in editor tool: summarize_scene");
+	}
+}
+
+void FModelContextProtocolEditorModule::DeregisterBuiltinEditorTools()
+{
+	if (IModelContextProtocolModule* Module = IModelContextProtocolModule::Get())
+	{
+		if (EditorContextTool.IsValid()) { Module->RemoveTool(EditorContextTool.ToSharedRef()); EditorContextTool.Reset(); }
+		if (ViewportTool.IsValid()) { Module->RemoveTool(ViewportTool.ToSharedRef()); ViewportTool.Reset(); }
+		if (SaveLevelTool.IsValid()) { Module->RemoveTool(SaveLevelTool.ToSharedRef()); SaveLevelTool.Reset(); }
+		if (ListLevelsTool.IsValid()) { Module->RemoveTool(ListLevelsTool.ToSharedRef()); ListLevelsTool.Reset(); }
+		if (ClassInventoryTool.IsValid()) { Module->RemoveTool(ClassInventoryTool.ToSharedRef()); ClassInventoryTool.Reset(); }
+		if (OpenLevelTool.IsValid()) { Module->RemoveTool(OpenLevelTool.ToSharedRef()); OpenLevelTool.Reset(); }
+		if (SnapshotWorldTool.IsValid()) { Module->RemoveTool(SnapshotWorldTool.ToSharedRef()); SnapshotWorldTool.Reset(); }
+		if (RestoreWorldTool.IsValid()) { Module->RemoveTool(RestoreWorldTool.ToSharedRef()); RestoreWorldTool.Reset(); }
+		if (SpawnActorTool.IsValid()) { Module->RemoveTool(SpawnActorTool.ToSharedRef()); SpawnActorTool.Reset(); }
+		if (SetActorTransformTool.IsValid()) { Module->RemoveTool(SetActorTransformTool.ToSharedRef()); SetActorTransformTool.Reset(); }
+		if (VerifyPositionTool.IsValid()) { Module->RemoveTool(VerifyPositionTool.ToSharedRef()); VerifyPositionTool.Reset(); }
+		if (SummarizeSceneTool.IsValid()) { Module->RemoveTool(SummarizeSceneTool.ToSharedRef()); SummarizeSceneTool.Reset(); }
+	}
+}
