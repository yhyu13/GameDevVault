# Phase 3: capture_viewport Tool
# UE5 MCP Extension -- Compiles on UE5.8
#
# This patch adds a built-in MCP tool that captures the current editor viewport
# as a PNG image and returns it as a base64-encoded image for multi-modal LLM analysis.
#
# Prerequisites: Phase 2 (get_editor_context) must be applied first.
#
# Apply: cd Engine/Plugins/Experimental/ModelContextProtocol && patch -p5 < phase3_capture_viewport.patch

--- a/Engine/Plugins/Experimental/ModelContextProtocol/Source/ModelContextProtocolEditor/Public/ModelContextProtocolEditor.h
+++ b/Engine/Plugins/Experimental/ModelContextProtocol/Source/ModelContextProtocolEditor/Public/ModelContextProtocolEditor.h
@@ -10,6 +10,8 @@
 
 struct FModelContextProtocolEditorContextTool;
+struct FModelContextProtocolViewportTool;
+
 class FModelContextProtocolEditorModule : public IModuleInterface
 {
 public:
@@ -30,5 +32,6 @@ private:
 	FDelegateHandle OnToolsetRegisteredHandle;
 	TSharedPtr<FModelContextProtocolEditorContextTool> EditorContextTool;
+	TSharedPtr<FModelContextProtocolViewportTool> ViewportTool;
 };

--- a/Engine/Plugins/Experimental/ModelContextProtocol/Source/ModelContextProtocolEditor/Private/ModelContextProtocolEditor.cpp
+++ b/Engine/Plugins/Experimental/ModelContextProtocol/Source/ModelContextProtocolEditor/Private/ModelContextProtocolEditor.cpp
@@ -8,6 +8,7 @@
 #include "ModelContextProtocolToolLibrary.h"
 #include "ModelContextProtocolEditorContextTool.h"
