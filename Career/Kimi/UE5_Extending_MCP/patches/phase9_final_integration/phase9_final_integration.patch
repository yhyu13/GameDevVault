+void FModelContextProtocolEditorModule::DeregisterBuiltinEditorTools()
+{
+	if (IModelContextProtocolModule* Module = IModelContextProtocolModule::Get())
+	{
+		if (EditorContextTool.IsValid()) { Module->RemoveTool(EditorContextTool.ToSharedRef()); EditorContextTool.Reset(); }
+		if (ViewportTool.IsValid()) { Module->RemoveTool(ViewportTool.ToSharedRef()); ViewportTool.Reset(); }
+		if (SaveLevelTool.IsValid()) { Module->RemoveTool(SaveLevelTool.ToSharedRef()); SaveLevelTool.Reset(); }
+		if (ListLevelsTool.IsValid()) { Module->RemoveTool(ListLevelsTool.ToSharedRef()); ListLevelsTool.Reset(); }
+		if (ClassInventoryTool.IsValid()) { Module->RemoveTool(ClassInventoryTool.ToSharedRef()); ClassInventoryTool.Reset(); }
+		if (OpenLevelTool.IsValid()) { Module->RemoveTool(OpenLevelTool.ToSharedRef()); OpenLevelTool.Reset(); }
+		if (SnapshotWorldTool.IsValid()) { Module->RemoveTool(SnapshotWorldTool.ToSharedRef()); SnapshotWorldTool.Reset(); }
+		if (RestoreWorldTool.IsValid()) { Module->RemoveTool(RestoreWorldTool.ToSharedRef()); RestoreWorldTool.Reset(); }
+		if (SpawnActorTool.IsValid()) { Module->RemoveTool(SpawnActorTool.ToSharedRef()); SpawnActorTool.Reset(); }
+		if (SetActorTransformTool.IsValid()) { Module->RemoveTool(SetActorTransformTool.ToSharedRef()); SetActorTransformTool.Reset(); }
+		if (VerifyPositionTool.IsValid()) { Module->RemoveTool(VerifyPositionTool.ToSharedRef()); VerifyPositionTool.Reset(); }
+		if (SummarizeSceneTool.IsValid()) { Module->RemoveTool(SummarizeSceneTool.ToSharedRef()); SummarizeSceneTool.Reset(); }
+		if (SearchActorsTool.IsValid()) { Module->RemoveTool(SearchActorsTool.ToSharedRef()); SearchActorsTool.Reset(); }
+		if (ListBlueprintsTool.IsValid()) { Module->RemoveTool(ListBlueprintsTool.ToSharedRef()); ListBlueprintsTool.Reset(); }
+		if (SetVisibilityTool.IsValid()) { Module->RemoveTool(SetVisibilityTool.ToSharedRef()); SetVisibilityTool.Reset(); }
+		if (SetMobilityTool.IsValid()) { Module->RemoveTool(SetMobilityTool.ToSharedRef()); SetMobilityTool.Reset(); }
+		if (SetCollisionTool.IsValid()) { Module->RemoveTool(SetCollisionTool.ToSharedRef()); SetCollisionTool.Reset(); }
+	}
+}
