+void FModelContextProtocolEditorModule::RegisterBuiltinEditorTools()
+{
+	IModelContextProtocolModule* Module = IModelContextProtocolModule::Get();
+	if (!Module)
+	{
+		return;
+	}
+
+	EditorContextTool = MakeShared<FModelContextProtocolEditorContextTool>();
+	if (Module->AddTool(EditorContextTool.ToSharedRef()))
+	{
+		UE_LOGF(LogModelContextProtocol, Log, "Registered built-in editor tool: get_editor_context");
+	}
+}
+
+void FModelContextProtocolEditorModule::DeregisterBuiltinEditorTools()
+{
+	if (IModelContextProtocolModule* Module = IModelContextProtocolModule::Get())
+	{
+		if (EditorContextTool.IsValid())
+		{
+			Module->RemoveTool(EditorContextTool.ToSharedRef());
+			EditorContextTool.Reset();
+		}
+	}
+}
+
