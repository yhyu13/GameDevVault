+// === Stdio transport ===
+
+namespace UE::ModelContextProtocol::Private
+{
+	void WriteStdioJsonLine(const TSharedPtr<FJsonObject>& JsonObject)
+	{
+		FString JsonStr;
+		TSharedRef<TJsonWriter<>> JsonWriter = TJsonWriterFactory<>::Create(&JsonStr);
+		FJsonSerializer::Serialize(JsonObject, JsonWriter);
+
+		FTCHARToUTF8 UTF8Str(*JsonStr);
+		fwrite(UTF8Str.Get(), sizeof(ANSICHAR), UTF8Str.Length(), stdout);
+		fwrite("\n", sizeof(ANSICHAR), 1, stdout);
+		fflush(stdout);
+	}
+
+	void WriteStdioErrorResponse(const TSharedPtr<FJsonValue>& RequestId, int32 ErrorCode, const FString& ErrorMessage)
+	{
+		FJsonDomBuilder::FObject ErrorObject;
+		ErrorObject.Set(TEXT("code"), ErrorCode);
+		ErrorObject.Set(TEXT("message"), ErrorMessage);
+
+		FJsonDomBuilder::FObject ResponseObject;
+		ResponseObject.Set(TEXT("jsonrpc"), UE::ModelContextProtocol::JsonRpcVersion);
+		ResponseObject.Set(TEXT("id"), RequestId.IsValid() ? RequestId : MakeShared<FJsonValueNull>());
+		ResponseObject.Set(TEXT("error"), ErrorObject);
+
+		WriteStdioJsonLine(ResponseObject.AsJsonObject());
+	}
+
+	void WriteStdioResultResponse(const TSharedPtr<FJsonValue>& RequestId, const TSharedPtr<FJsonValue>& Result)
+	{
+		FJsonDomBuilder::FObject ResponseObject;
+		ResponseObject.Set(TEXT("jsonrpc"), UE::ModelContextProtocol::JsonRpcVersion);
+		ResponseObject.Set(TEXT("id"), RequestId);
+		ResponseObject.Set(TEXT("result"), Result);
+
+		WriteStdioJsonLine(ResponseObject.AsJsonObject());
+	}
+
+	FHttpResultCallback CreateStdioResultCallback()
+	{
+		return [](TUniquePtr<FHttpServerResponse> Response)
+		{
+			if (!Response.IsValid() || Response->Code == EHttpServerResponseCodes::Accepted)
+			{
+				return;
+			}
+
+			if (Response->Body.Num() == 0)
+			{
+				return;
+			}
+
+			const FString BodyStr = FString(FUTF8ToTCHAR(reinterpret_cast<const UTF8CHAR*>(Response->Body.GetData()), Response->Body.Num()));
+
+			// SSE-formatted response: extract the data: line
+			if (BodyStr.Contains(TEXT("event: message")))
+			{
+				TArray<FString> Lines;
+				BodyStr.ParseIntoArray(Lines, TEXT("\n"));
+				for (const FString& Line : Lines)
+				{
+					FString Trimmed = Line.TrimStartAndEnd();
+					if (Trimmed.StartsWith(TEXT("data: ")))
+					{
+						FString JsonData = Trimmed.RightChop(6);
+						FTCHARToUTF8 UTF8Data(*JsonData);
+						fwrite(UTF8Data.Get(), sizeof(ANSICHAR), UTF8Data.Length(), stdout);
+						fwrite("\n", sizeof(ANSICHAR), 1, stdout);
+						fflush(stdout);
+						break;
+					}
+				}
+			}
+			else
+			{
+				// Plain JSON response
+				FTCHARToUTF8 UTF8Body(*BodyStr);
+				fwrite(UTF8Body.Get(), sizeof(ANSICHAR), UTF8Body.Length(), stdout);
+				fwrite("\n", sizeof(ANSICHAR), 1, stdout);
+				fflush(stdout);
+			}
+		};
+	}
+}
+
+class FModelContextProtocolStdioRunnable : public FRunnable
+{
+public:
+	FModelContextProtocolStdioRunnable(FModelContextProtocolServer* InServer)
+		: Server(InServer)
+		, bRunning(true)
+	{}
+
+	virtual uint32 Run() override
+	{
+		while (bRunning)
+		{
+			constexpr int32 BufferSize = 65536;
+			char Buffer[BufferSize];
+			if (fgets(Buffer, BufferSize, stdin) == nullptr)
+			{
+				break;
+			}
+
+			// Strip trailing newline / carriage return
+			size_t Len = strlen(Buffer);
+			if (Len > 0 && Buffer[Len - 1] == '\n')
+			{
+				Buffer[Len - 1] = '\0';
+				--Len;
+			}
+			if (Len > 0 && Buffer[Len - 1] == '\r')
+			{
+				Buffer[Len - 1] = '\0';
+			}
+
+			FString Line = FString(FUTF8ToTCHAR(Buffer).Get());
+
+			// Parse JSON
+			TSharedPtr<FJsonObject> JsonObject = MakeShared<FJsonObject>();
+			TSharedRef<TJsonReader<>> JsonReader = TJsonReaderFactory<>::Create(Line);
+			if (!FJsonSerializer::Deserialize(JsonReader, JsonObject) || !JsonObject.IsValid())
+			{
+				UE::ModelContextProtocol::Private::WriteStdioErrorResponse(
+					nullptr,
+					static_cast<int32>(UE::ModelContextProtocol::Private::EJsonRpcErrorCode::ParseError),
+					TEXT("Parse error"));
+				continue;
+			}
+
+			// jsonrpc
+			FString RequestJsonRpcVersion;
+			if (!JsonObject->TryGetStringField(TEXT("jsonrpc"), RequestJsonRpcVersion) || RequestJsonRpcVersion != UE::ModelContextProtocol::JsonRpcVersion)
+			{
+				UE::ModelContextProtocol::Private::WriteStdioErrorResponse(
+					nullptr,
+					static_cast<int32>(UE::ModelContextProtocol::Private::EJsonRpcErrorCode::InvalidRequest),
+					FString::Printf(TEXT("Unexpected jsonrpc version %s. Must be %s"), *RequestJsonRpcVersion, UE::ModelContextProtocol::JsonRpcVersion));
+				continue;
+			}
+
+			// id
+			TSharedPtr<FJsonValue> RequestId = JsonObject->TryGetField(TEXT("id"));
+
+			// method
+			FString Method;
+			if (!JsonObject->TryGetStringField(TEXT("method"), Method))
+			{
+				UE::ModelContextProtocol::Private::WriteStdioErrorResponse(
+					RequestId,
+					static_cast<int32>(UE::ModelContextProtocol::Private::EJsonRpcErrorCode::InvalidRequest),
+					TEXT("Missing required field \"method\""));
+				continue;
+			}
+
+			// params
+			const TSharedPtr<FJsonObject>* ParamsObject = nullptr;
+			JsonObject->TryGetObjectField(TEXT("params"), ParamsObject);
+
+			// Marshal to game thread
+			TWeakPtr<bool> WeakAlive = Server->AliveGuard;
+			TSharedPtr<FJsonObject> Params = ParamsObject ? *ParamsObject : nullptr;
+			AsyncTask(ENamedThreads::GameThread, [WeakAlive, Server = Server, RequestId, Method, Params]()
+			{
+				if (!WeakAlive.IsValid())
+				{
+					return;
+				}
+				Server->ProcessStdioJsonRpcCall(RequestId, Method, Params);
+			});
+		}
+
+		return 0;
+	}
+
+	virtual void Stop() override
+	{
+		bRunning = false;
+	}
+
+private:
+	FModelContextProtocolServer* Server;
+	FThreadSafeBool bRunning;
+};
+
+void FModelContextProtocolServer::StartStdioTransport()
+{
+	if (StdioThread != nullptr)
+	{
+		UE_LOGF(LogModelContextProtocol, Warning, "Stdio transport already running");
+		return;
+	}
+
+	UE_LOGF(LogModelContextProtocol, Log, "Starting MCP stdio transport");
+
+	StdioRunnable = MakeShared<FModelContextProtocolStdioRunnable>(this);
+	StdioThread = FRunnableThread::Create(StdioRunnable.Get(), TEXT("MCPStdioTransport"));
+}
+
+void FModelContextProtocolServer::StopStdioTransport()
+{
+	if (StdioRunnable.IsValid())
+	{
+		StdioRunnable->Stop();
+	}
+
+	if (StdioThread != nullptr)
+	{
+		StdioThread->Kill(true);
+		delete StdioThread;
+		StdioThread = nullptr;
+	}
+
+	StdioRunnable.Reset();
+
+	if (StdioSession.IsValid() && StdioSession->Status == EModelContextProtocolSessionStatus::Initialized)
+	{
+		UE::ModelContextProtocol::Analytics::RecordSessionEndEvent(StdioSession->ID);
+	}
+	StdioSession.Reset();
+
+	UE_LOGF(LogModelContextProtocol, Log, "Stopped MCP stdio transport");
+}
+
+bool FModelContextProtocolServer::ProcessStdioJsonRpcCall(const TSharedPtr<FJsonValue>& RequestId, const FString& Method, const TSharedPtr<FJsonObject>& Params)
+{
+	FHttpServerRequest DummyRequest{};
+	DummyRequest.PeerAddress = nullptr;
+
+	const FHttpResultCallback StdioOnComplete = UE::ModelContextProtocol::Private::CreateStdioResultCallback();
+
+	if (Method == UE::ModelContextProtocol::Private::Methods::Ping)
+	{
+		return ProcessPingJsonRpcCall(DummyRequest, RequestId, StdioOnComplete);
+	}
+
+	if (Method == UE::ModelContextProtocol::Private::Methods::Initialize)
+	{
+		// Handle initialize specially to track the stdio session
+		FModelContextProtocolInitializeParams InitializeParams;
+		if (!UE::ModelContextProtocol::Private::ParseParamsOrError(TEXT("initialize"), RequestId, StdioOnComplete, Params, InitializeParams))
+		{
+			return true;
+		}
+
+		const FString NegotiatedVersion = UE::ModelContextProtocol::NegotiateProtocolVersion(InitializeParams.ProtocolVersion);
+		UE_LOGF(LogModelContextProtocol, Display, "Client requested protocol version '%ls', negotiated '%ls' (stdio)", *InitializeParams.ProtocolVersion, *NegotiatedVersion);
+
+		// Create new stdio session
+		TSharedPtr<FModelContextProtocolSession> NewSession = MakeShared<FModelContextProtocolSession>();
+		NewSession->ID = FGuid::NewGuid().ToString(EGuidFormats::DigitsLower);
+		NewSession->Status = EModelContextProtocolSessionStatus::Initializing;
+		NewSession->NegotiatedProtocolVersion = NegotiatedVersion;
+		NewSession->ClientAddress = nullptr;
+		NewSession->ClientCapabilities = InitializeParams.Capabilities;
+		Sessions.Add(NewSession);
+		StdioSession = NewSession;
+		UE_LOGF(LogModelContextProtocol, Log, "Initializing new stdio session: %ls", *NewSession->ID);
+
+		FModelContextProtocolInitializeResult InitializeResult;
+		InitializeResult.ProtocolVersion = NegotiatedVersion;
+		FModelContextProtocolToolsCapability ToolsCapability;
+		ToolsCapability.ListChanged = true;
+		InitializeResult.Capabilities.Tools = ToolsCapability;
+		InitializeResult.Capabilities.Resources = FModelContextProtocolResourcesCapability();
+		UE::ModelContextProtocol::Private::CompleteWithResult(StdioOnComplete, RequestId, InitializeResult, &NewSession->ID);
+		return true;
+	}
+
+	// Validate session exists for all other methods
+	if (!StdioSession.IsValid())
+	{
+		UE::ModelContextProtocol::Private::WriteStdioErrorResponse(
+			RequestId,
+			static_cast<int32>(UE::ModelContextProtocol::Private::EJsonRpcErrorCode::InvalidRequest),
+			FString::Printf(TEXT("No active session for '%s'; call initialize first"), *Method));
+		return true;
+	}
+
+	if (!UE::ModelContextProtocol::Private::GetPostInitMethods().Contains(Method))
+	{
+		UE::ModelContextProtocol::Private::WriteStdioErrorResponse(
+			RequestId,
+			static_cast<int32>(UE::ModelContextProtocol::Private::EJsonRpcErrorCode::MethodNotFound),
+			FString::Printf(TEXT("Call to unknown method \"%s\""), *Method));
+		return true;
+	}
+
+	const TSharedRef<FModelContextProtocolSession> SessionRef = StdioSession.ToSharedRef();
+
+	if (Method == UE::ModelContextProtocol::Private::Methods::NotificationsInitialized)
+	{
+		return ProcessInitializedNotificationJsonRpcCall(DummyRequest, RequestId, Params, SessionRef, StdioOnComplete);
+	}
+
+	if (Method == UE::ModelContextProtocol::Private::Methods::NotificationsCancelled)
+	{
+		return ProcessNotificationCancelledJsonRpcCall(DummyRequest, RequestId, Params, SessionRef, StdioOnComplete);
+	}
+
+	if (Method == UE::ModelContextProtocol::Private::Methods::ToolsList)
+	{
+		return ProcessListToolsJsonRpcCall(DummyRequest, RequestId, Params, SessionRef, StdioOnComplete);
+	}
+
+	if (Method == UE::ModelContextProtocol::Private::Methods::ToolsCall)
+	{
+		return ProcessStdioToolCallJsonRpcCall(RequestId, Params, SessionRef);
+	}
+
+	if (Method == UE::ModelContextProtocol::Private::Methods::ResourcesList)
+	{
+		return ProcessListResourcesJsonRpcCall(DummyRequest, RequestId, Params, SessionRef, StdioOnComplete);
+	}
+
+	if (Method == UE::ModelContextProtocol::Private::Methods::ResourcesRead)
+	{
+		return ProcessReadResourceJsonRpcCall(DummyRequest, RequestId, Params, SessionRef, StdioOnComplete);
+	}
+
+	return true;
+}
+
+bool FModelContextProtocolServer::ProcessStdioToolCallJsonRpcCall(const TSharedPtr<FJsonValue>& RequestId, const TSharedPtr<FJsonObject>& Params, const TSharedRef<FModelContextProtocolSession>& Session)
+{
+	FHttpServerRequest DummyRequest{};
+	return ProcessToolCallJsonRpcCall(DummyRequest, RequestId, Params, Session, UE::ModelContextProtocol::Private::CreateStdioResultCallback());
+}
